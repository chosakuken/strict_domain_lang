{
  "name": "strict-domain-lang",
  "version": "0.0.0",
  "description": "厳格な定義域を設けた言語処理系",
  "type": "module",
  "bin": {
    "stl": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc src/index.ts",
    "generate:parser": "antlr-ng -Dlanguage=TypeScript -o src/parser/generated grammar/StrictDomainLangLexer.g4 grammar/StrictDomainLangParser.g4",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "fix": "prettier --write src/**/*.ts",
    "lint": "eslint src/**/*.ts && prettier --check src/**/*.ts && npm run typecheck"
  },
  "dependencies": {
    "antlr4ng": "^3.0.16",
    "commander": "^15.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@typescript-eslint/parser": "^8.60.1",
    "antlr-ng": "^1.0.10",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "engines": {
    "node": ">=20"
  }
}
